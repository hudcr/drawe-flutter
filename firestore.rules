rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{code} {
      // Any authenticated user can read room state (for lobby/game listeners)
      allow read: if request.auth != null;
      // All writes go through Cloud Functions (firebase-admin bypasses rules)
      allow write: if false;

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /drawings/{drawingId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
